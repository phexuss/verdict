# Version control
.git
.gitignore

# Turbo cache
.turbo
**/.turbo

# Dependencies — Docker installs fresh inside the image
node_modules
**/node_modules

# Build artifacts — builder stage compiles from source
dist
**/dist
.next
**/.next

# Web app — deployed to Vercel, never needed in the Docker build context.
# This is the biggest win: excludes Next.js, React, and all UI deps.
apps/web
packages/ui

# Generated Prisma client — regenerated inside the builder stage
apps/api/src/generated

# Dev / editor files
.env*.local
*.log
npm-debug.log*
.DS_Store
.vscode
.idea

# Tests
**/__tests__
**/*.test.ts
**/*.spec.ts
**/*.test.js
**/*.spec.js

# CI / docs
.github
docs
*.md
